<%- include('partials/header') %>

<section class="form-container">
  <h2><i class="fas fa-user-plus"></i> إنشاء حساب جديد</h2>
  <% if (error) { %>
    <div class="error"><%= error %></div>
  <% } %>
  <form action="/register" method="POST" enctype="multipart/form-data">
    <div class="form-group">
      <label><i class="fas fa-user"></i> اسم المستخدم</label>
      <input type="text" name="username" required>
    </div>
    <div class="form-group">
      <label><i class="fas fa-lock"></i> كلمة المرور</label>
      <input type="password" name="password" required>
    </div>
    <div class="form-group">
      <label><i class="fas fa-image"></i> صورة الأفتار (اختياري)</label>
      <input type="file" name="avatar" accept="image/*">
    </div>
    <button type="submit" class="btn"><i class="fas fa-check"></i> تسجيل</button>
  </form>
  <p>لديك حساب بالفعل؟ <a href="/login">سجل دخول</a></p>
</section>

<%- include('partials/footer') %>
