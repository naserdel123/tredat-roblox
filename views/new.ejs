<%- include('partials/header') %>

<section class="form-container">
  <h2><i class="fas fa-plus-circle"></i> نشر تريدة جديدة</h2>
  <% if (error) { %>
    <div class="error"><%= error %></div>
  <% } %>
  <form action="/posts/new" method="POST" enctype="multipart/form-data">
    <div class="form-group">
      <label><i class="fas fa-tag"></i> اسم العنصر</label>
      <input type="text" name="itemName" required>
    </div>
    <div class="form-group">
      <label><i class="fas fa-image"></i> صورة العنصر</label>
      <input type="file" name="itemImage" accept="image/*" required>
    </div>
    <div class="form-group">
      <label><i class="fas fa-exchange-alt"></i> المقابل (ماذا تريد؟)</label>
      <input type="text" name="want" required>
    </div>
    <div class="form-group">
      <label><i class="fas fa-image"></i> صورة المقابل</label>
      <input type="file" name="wantImage" accept="image/*" required>
    </div>
    <div class="form-group">
      <label><i class="fab fa-tiktok"></i> رابط حسابك في التيك توك</label>
      <input type="url" name="tiktokUrl" required placeholder="https://tiktok.com/@...">
    </div>
    <button type="submit" class="btn"><i class="fas fa-paper-plane"></i> نشر</button>
  </form>
</section>

<%- include('partials/footer') %>
