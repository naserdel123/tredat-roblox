<%- include('partials/header') %>

<section class="form-container">
  <h2><i class="fas fa-sign-in-alt"></i> تسجيل الدخول</h2>
  <% if (error) { %>
    <div class="error"><%= error %></div>
  <% } %>
  <form action="/login" method="POST">
    <div class="form-group">
      <label><i class="fas fa-user"></i> اسم المستخدم</label>
      <input type="text" name="username" required>
    </div>
    <div class="form-group">
      <label><i class="fas fa-lock"></i> كلمة المرور</label>
      <input type="password" name="password" required>
    </div>
    <button type="submit" class="btn"><i class="fas fa-arrow-right"></i> دخول</button>
  </form>
  <p>ليس لديك حساب؟ <a href="/register">سجل الآن</a></p>
</section>

<%- include('partials/footer') %>
